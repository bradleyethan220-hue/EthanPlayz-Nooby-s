<!DOCTYPE html>
<html>
<head>
  <title>Ethan Fan Website</title>
  <style>
    body {
      background: #000;
      font-family: Arial, sans-serif;
      margin: 0;
      color: white;
    }

    /* DOORS Login Center */
    #loginBox {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background: linear-gradient(180deg, #000, #111);
    }

    .login-box {
      background: #0d0d0d;
      padding: 35px;
      width: 360px;
      border-radius: 8px;
      box-shadow: 0 0 25px rgba(255, 215, 0, 0.2);
      border: 2px solid #222;
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
      font-weight: 600;
      color: #f5d742;
      text-shadow: 0 0 10px #f5d742;
    }

    .input {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      border: 1px solid #333;
      border-radius: 4px;
      background: #000;
      color: white;
      font-size: 15px;
    }

    .input:focus {
      outline: none;
      border-color: #f5d742;
      box-shadow: 0 0 10px #f5d742;
    }

    .button {
      width: 100%;
      padding: 12px;
      background: #f5d742;
      border: none;
      border-radius: 4px;
      color: #000;
      font-size: 17px;
      cursor: pointer;
      margin-top: 10px;
      font-weight: bold;
      text-shadow: 0 0 5px #fff;
    }

    .button:hover {
      background: #ffe066;
    }

    /* Content Section */
    #content {
      display: none;
      padding: 20px;
      text-align: center;
    }

    .video-box {
      margin-bottom: 40px;
    }

    img.thumbnail {
      width: 300px;
      border-radius: 10px;
      margin-bottom: 10px;
      box-shadow: 0 0 15px rgba(255, 215, 0, 0.3);
    }

    img.icon {
      width: 130px;
      border-radius: 50%;
      margin-bottom: 10px;
      border: 3px solid #f5d742;
      box-shadow: 0 0 20px #f5d742;
    }

    .glowText {
      font-size: 22px;
      color: #f5d742;
      text-shadow: 0 0 10px #f5d742, 0 0 20px #f5d742;
      margin-bottom: 20px;
    }
  </style>
</head>

<body>

  <!-- LOGIN PAGE -->
  <div id="loginBox">
    <div class="login-box">
      <h2>DOORS Login</h2>

      <input id="displayName" class="input" placeholder="Display Name">
      <input id="password" class="input" type="password" placeholder="Password">

      <button class="button" onclick="login()">Enter</button>
    </div>
  </div>

  <!-- MAIN CONTENT AFTER LOGIN -->
  <div id="content">

    <!-- Your Icon -->
    <img class="icon" src="https://yt3.googleusercontent.com/y1eCSSYk1Bfwhz1fgdo_50VMsSCJQDso30IdHo3gcM6BFrzMfZ2PCIgC3R-Z1yoABt8GKTfEbw=s160-c-k-c0x00ffffff-no-rj">

    <!-- Glowing Text -->
    <div class="glowText">Latest Upload</div>

    <h1>Welcome to Ethan's DOORS Fan Website</h1>
    <h2 style="color:#f5d742; text-shadow:0 0 10px #f5d742;">Newest 3 Videos</h2>

    <!-- VIDEO 1 (Your latest video) -->
    <div class="video-box">
      <img class="thumbnail" src="https://i.ytimg.com/an_webp/lzlmpB5FggQ/mqdefault_6s.webp?du=3000&sqp=CNiFrc0G&rs=AOn4CLDwPy_pK61CB1qMlZbndxyMN8whSQ">

      <iframe width="560" height="315"
        src="https://www.youtube.com/embed/lzlmpB5FggQ?start=870"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen>
      </iframe>
    </div>

    <!-- VIDEO 2 Placeholder -->
    <div class="video-box">
      <img class="thumbnail" src="https://via.placeholder.com/300x200?text=Video+2+Thumbnail">
      <iframe width="560" height="315"
        src="https://www.youtube.com/embed/VIDEO_ID_HERE"
        frameborder="0"
        allowfullscreen>
      </iframe>
    </div>

    <!-- VIDEO 3 Placeholder -->
    <div class="video-box">
      <img class="thumbnail" src="https://via.placeholder.com/300x200?text=Video+3+Thumbnail">
      <iframe width="560" height="315"
        src="https://www.youtube.com/embed/VIDEO_ID_HERE"
        frameborder="0"
        allowfullscreen>
      </iframe>
    </div>

  </div>

  <script>
    function login() {
      const name = document.getElementById("displayName").value;

      if (name.trim() === "") {
        alert("Please enter a display name.");
        return;
      }

      document.getElementById("loginBox").style.display = "none";
      document.getElementById("content").style.display = "block";
    }
  </script>

</body>
</html>
